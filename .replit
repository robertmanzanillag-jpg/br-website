entrypoint = "index.js"
modules = ["nodejs-20", "python-3.11", "postgresql-16"]

[nix]
channel = "stable-25_05"
packages = ["alsa-lib", "at-spi2-atk", "atk", "cairo", "chromium", "cups", "dbus-glib", "expat", "glib", "gtk3", "libdrm", "libxkbcommon", "mesa", "nspr", "nss", "pango", "xorg.libX11", "xorg.libXcomposite", "xorg.libXdamage", "xorg.libXext", "xorg.libXfixes", "xorg.libXinerama", "xorg.libXrandr", "xorg.libxcb", "zip"]

[[nix.deps]]
name = "glib"

[[nix.deps]]
name = "glibc"

[[nix.deps]]
name = "gtk3"

[[nix.deps]]
name = "at-spi2-atk"

[[nix.deps]]
name = "at-spi2-core"

[[nix.deps]]
name = "libdrm"

[[nix.deps]]
name = "xorg.libxcb"

[[nix.deps]]
name = "xorg.libXcomposite"

[[nix.deps]]
name = "xorg.libXdamage"

[[nix.deps]]
name = "xorg.libXfixes"

[[nix.deps]]
name = "xorg.libXrandr"

[[nix.deps]]
name = "mesa"

[[nix.deps]]
name = "expat"

[[nix.deps]]
name = "alsa-lib"

[[nix.deps]]
name = "nss"

[[nix.deps]]
name = "nspr"

[deployment]
run = ["node", "index.js"]
deploymentTarget = "autoscale"

[[ports]]
localPort = 5000
externalPort = 80

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Start Server"
author = 41802083
mode = "sequential"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "node index.js"

[[workflows.workflow]]
name = "Start Black Room App"
author = 41802083
mode = "sequential"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "pkill -f \"node index.js\" || true"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "sleep 2"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "node index.js"

[[workflows.workflow]]
name = "Start App"
author = 41802083
mode = "sequential"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "node index.js"

[[workflows.workflow]]
name = "Run Server"
author = 41802083
mode = "sequential"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "node index.js"

[[workflows.workflow]]
name = "Start Black Room Server"
author = 41802083
mode = "sequential"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "pkill -f \"node\" || true"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "sleep 3"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "node --version"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "npm --version"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "PORT=5000 node index.js"

